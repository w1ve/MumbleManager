# =============================================================================
# MumbleManager — Environment Configuration Template
# Author:  Gerald Hull, W1VE
# Date:    April 14, 2026
# License: MIT License
#
# Copy this file to .env and fill in your values before running deploy.sh
# or docker compose up.
#
#   cp .env.example .env
#   nano .env
# =============================================================================

# ── Domain ────────────────────────────────────────────────────────────────────
# Your fully-qualified domain name. Must match what's in nginx/nginx.conf.
DOMAIN=your.domain.com

# ── Port bindings ─────────────────────────────────────────────────────────────
# Host ports that Nginx listens on. Change if 80/443 are already in use.
HTTP_PORT=80
HTTPS_PORT=443

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Random string used to sign JWT tokens. Must be at least 32 characters.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=YOUR_JWT_SECRET_KEY_MIN_32_CHARS

# ── Email (SMTP via Gmail) ────────────────────────────────────────────────────
# MumbleManager sends account creation, password-change, and error notification
# emails. If you do not configure email, the app still works — emails are
# silently skipped.
#
# To use Gmail, enable 2-Factor Authentication on your Google account, then
# generate an App Password at: https://myaccount.google.com/apppasswords
EMAIL_FROM=YOUR_FROM_EMAIL@example.com
EMAIL_FROM_NAME=MumbleManager
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_APP_PASSWORD=YOUR_GMAIL_APP_PASSWORD
EMAIL_ADMIN_ADDRESS=YOUR_ADMIN_EMAIL@example.com

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API. Not usually needed when
# traffic is routed through Nginx, but useful for local development.
# ALLOWED_ORIGINS=https://your.domain.com,http://localhost:5173
